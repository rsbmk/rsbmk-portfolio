---
interface Props {
  title: string;
  description: string;
  link: string;
}

const { title, description, link } = Astro.props;
---

<a
  href={link}
  target="_blank"
  rel="noopener noreferrer"
  class="p-6 block border rounded-lg shadow bg-gray-800 border-gray-700 transition-all duration-200 ease-out hover:scale-105"
>
  <div class="mb-2 text-2xl font-semibold tracking-tight text-white flex gap-2">
    <slot name="icon" />
    <h5>
      {title}
    </h5>
  </div>
  <p class="mb-3 font-normal text-gray-400">{description}</p>
</a>
